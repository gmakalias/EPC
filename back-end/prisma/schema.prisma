// backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================
// 1. IDENTITY & ACCESS MANAGEMENT (RBAC)
// =============================================

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  username      String     @unique
  fullName      String?
  passwordHash  String
  isActive      Boolean    @default(true)
  isVerified    Boolean    @default(false)
  roles         UserRole[]
  createdSpecs  ProductSpecification[]
  createdOffers ProductOffering[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Role {
  id           String           @id @default(uuid())
  name         String           @unique
  description  String?
  isSystemRole Boolean          @default(false)
  permissions  RolePermission[]
  users        UserRole[]
}

model Permission {
  id          String           @id @default(uuid())
  name        String           @unique // e.g., 'product.create'
  resource    String           // e.g., 'product'
  action      String           // e.g., 'create'
  description String?
  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

// =============================================
// 2. PRODUCT CATALOGUE (TMF620)
// =============================================

model Category {
  id           String                 @id
  name         String
  description  String?
  isRoot       Boolean                @default(false)
  parentId     String?
  parent       Category?              @relation("SubCategories", fields: [parentId], references: [id])
  children     Category[]             @relation("SubCategories")
  displayOrder Int                    @default(0)
  path         String
  level        Int
  icon         String?
  specs        ProductSpecification[]
}

model ProductSpecification {
  id              String           @id @default(uuid())
  name            String
  description     String?
  productNumber   String?          @unique
  version         String           @default("1.0")
  status          String           @default("active")
  categoryId      String
  category        Category         @relation(fields: [categoryId], references: [id])
  createdById     String
  createdBy       User             @relation(fields: [createdById], references: [id])
  characteristics Characteristic[]
  offerings       ProductOffering[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Characteristic {
  id            String               @id @default(uuid())
  name          String
  description   String?
  valueType     String               // number, string, enum, etc.
  unitOfMeasure String?
  isRequired    Boolean              @default(false)
  defaultValue  String?
  allowedValues String[]             // Array for enum types
  specId        String
  spec          ProductSpecification @relation(fields: [specId], references: [id])
}

model ProductOffering {
  id              String                @id @default(uuid())
  name            String
  description     String?
  version         String                @default("1.0")
  status          String                @default("active")
  isSellable      Boolean               @default(true)
  sellingMode     String                @default("online")
  validForStart   DateTime?
  validForEnd     DateTime?
  specificationId String
  specification   ProductSpecification  @relation(fields: [specificationId], references: [id])
  createdById     String
  createdBy       User                  @relation(fields: [createdById], references: [id])
  metadata        Json?                 // For operator-specific codes
  channelMappings OfferingChannel[]
  pricingPlans    PricingPlan[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
}

// =============================================
// 3. CHANNELS & PRICING
// =============================================

model DistributionChannel {
  id          String            @id @default(uuid())
  name        String            @unique
  channelType String            // online, retail, partner
  description String?
  isActive    Boolean           @default(true)
  offerings   OfferingChannel[]
}

model OfferingChannel {
  offeringId String
  channelId  String
  isEnabled  Boolean             @default(true)
  displayOrder Int               @default(0)
  offering   ProductOffering     @relation(fields: [offeringId], references: [id])
  channel    DistributionChannel @relation(fields: [channelId], references: [id])

  @@id([offeringId, channelId])
}

model PricingPlan {
  id              String           @id @default(uuid())
  offeringId      String
  offering        ProductOffering  @relation(fields: [offeringId], references: [id])
  name            String
  description     String?
  pricingType     String           // recurring, one_time
  currency        String           @default("EUR")
  isActive        Boolean          @default(true)
  priceComponents PriceComponent[]
}

model PriceComponent {
  id               String      @id @default(uuid())
  pricingPlanId    String
  pricingPlan      PricingPlan @relation(fields: [pricingPlanId], references: [id])
  name             String
  componentType    String      // recurring, setup, etc.
  amount           Float
  currency         String      @default("EUR")
  recurrencePeriod String?     // monthly, yearly
}

// =============================================
// 4. SERVICE & RESOURCE INVENTORY (TMF638)
// =============================================

model CfsService {
  id          String       @id @default(uuid())
  name        String
  description String?
  serviceType String
  parameters  Json?        // e.g., { "codec": "AMR-WB" }
  rfsServices RfsService[]
}

model RfsService {
  id           String               @id @default(uuid())
  name         String
  description  String?
  serviceType  String
  cfsServiceId String
  cfsService   CfsService           @relation(fields: [cfsServiceId], references: [id])
  parameters   Json?
  resources    RfsResourceMapping[]
}

model Resource {
  id           String               @id @default(uuid())
  name         String
  resourceType String               // msisdn, sim, ip
  status       String               @default("available")
  parameters   Json?
  rfsMappings  RfsResourceMapping[]
}

model RfsResourceMapping {
  rfsServiceId String
  resourceId   String
  rfsService   RfsService @relation(fields: [rfsServiceId], references: [id])
  resource     Resource   @relation(fields: [resourceId], references: [id])

  @@id([rfsServiceId, resourceId])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // CREATE, UPDATE, DELETE
  entity    String   // Table Name
  details   Json
  timestamp DateTime @default(now())
}