# Stage 1: Build
FROM node:20-alpine AS builder
WORKDIR /app

# Use ci for faster, more reliable builds in Docker
COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

# Stage 2: Production (Nginx)
FROM nginx:alpine AS production

# Set working directory for clarity
WORKDIR /usr/share/nginx/html

# Copy custom nginx config
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Copy built assets from builder stage
COPY --from=builder /app/dist .

# The 'nginx' user already exists in nginx:alpine. 
# We just ensure it has permissions to the necessary directories.
RUN touch /var/run/nginx.pid && \
    chown -R nginx:nginx /var/run/nginx.pid /usr/share/nginx/html /var/cache/nginx /var/log/nginx /etc/nginx/conf.d

# Security: Run as non-root user
USER nginx

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=3s \
    CMD wget --quiet --tries=1 --spider http://localhost/ || exit 1

# Note: Do NOT override this command in docker-compose with 'npm run dev'
CMD ["nginx", "-g", "daemon off;"]